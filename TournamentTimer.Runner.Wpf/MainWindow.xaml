<Window x:Class="TournamentTimer.Runner.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="TournamentTimer Runner"
        Width="1040"
        Height="760"
        MinWidth="760"
        MinHeight="620"
        Background="#0B0D12"
        Foreground="#E8ECF7"
        WindowStartupLocation="CenterScreen"
        Icon="assets/branding/tournament-timer.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackground" Color="#0B0D12"/>
        <SolidColorBrush x:Key="CardBackground" Color="#151923"/>
        <SolidColorBrush x:Key="CardBackgroundSoft" Color="#10141D"/>
        <SolidColorBrush x:Key="FieldBackground" Color="#090B10"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#2A3040"/>
        <SolidColorBrush x:Key="TextMain" Color="#E8ECF7"/>
        <SolidColorBrush x:Key="TextStrong" Color="#F4F7FF"/>
        <SolidColorBrush x:Key="TextMuted" Color="#AAB3C5"/>
        <SolidColorBrush x:Key="Accent" Color="#2F6BFF"/>
        <SolidColorBrush x:Key="AccentHover" Color="#3D78FF"/>
        <SolidColorBrush x:Key="Danger" Color="#A83232"/>
        <SolidColorBrush x:Key="DangerHover" Color="#BA3D3D"/>
        <SolidColorBrush x:Key="Secondary" Color="#2A3040"/>
        <SolidColorBrush x:Key="SecondaryHover" Color="#343C51"/>

        <Style x:Key="MutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource FieldBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="11,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SelectionBrush" Value="{StaticResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource FieldBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="11,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="#343C51"
                                BorderBrush="#475069"
                                BorderThickness="1"
                                CornerRadius="6"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="{StaticResource FieldBackground}"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.LineUpCommand}"
                                                  Opacity="0"
                                                  IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="2"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.LineDownCommand}"
                                                  Opacity="0"
                                                  IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0B0D12" Offset="0"/>
                <GradientStop Color="#111827" Offset="0.55"/>
                <GradientStop Color="#0B0D12" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer x:Name="PageScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="TournamentTimer Runner"
                                   Foreground="{StaticResource TextStrong}"
                                   FontSize="28"
                                   FontWeight="Black"/>
                        <TextBlock Text="Runner client · Start / Split · LiveSplit bridge"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="14"
                                   Margin="2,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#202536"
                            BorderBrush="#343B52"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="12,6"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="ClientBadgeTextBlock"
                                   Text="runner client"
                                   Foreground="{StaticResource TextMain}"
                                   FontSize="12"
                                   FontWeight="Bold"/>
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Background="{StaticResource CardBackground}"
                        BorderBrush="#2A3040"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="16"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Connection / Controls"
                                   Style="{StaticResource MutedLabel}"/>

                        <WrapPanel Grid.Row="1"
                                   Orientation="Horizontal"
                                   Margin="0,0,0,10">
                            <StackPanel Width="270" Margin="0,0,12,10">
                                <TextBlock Text="Server URL" Style="{StaticResource MutedLabel}"/>
                                <TextBox x:Name="ServerUrlTextBox"/>
                            </StackPanel>

                            <StackPanel Width="160" Margin="0,0,12,10">
                                <TextBlock Text="Run ID" Style="{StaticResource MutedLabel}"/>
                                <TextBox x:Name="RunIdTextBox"/>
                            </StackPanel>

                            <StackPanel Width="145" Margin="0,0,12,10">
                                <TextBlock Text="Runner ID" Style="{StaticResource MutedLabel}"/>
                                <TextBox x:Name="RunnerIdTextBox"/>
                            </StackPanel>

                            <StackPanel Width="185" Margin="0,0,12,10">
                                <TextBlock Text="Run key" Style="{StaticResource MutedLabel}"/>
                                <PasswordBox x:Name="RunKeyPasswordBox"/>
                            </StackPanel>

                            <StackPanel Width="124" Margin="0,0,10,10">
                                <TextBlock Text="Button spacer"
                                           Style="{StaticResource MutedLabel}"
                                           Visibility="Hidden"/>
                                <Button x:Name="ConnectButton"
                                        Content="Connect"
                                        Height="40"
                                        Click="ConnectButton_Click"/>
                            </StackPanel>

                            <StackPanel Width="142" Margin="0,0,10,10">
                                <TextBlock Text="Button spacer"
                                           Style="{StaticResource MutedLabel}"
                                           Visibility="Hidden"/>
                                <Button x:Name="ActionButton"
                                        Content="Start / Split"
                                        Height="40"
                                        Click="ActionButton_Click"/>
                            </StackPanel>

                            <StackPanel Width="136" Margin="0,0,12,10">
                                <TextBlock Text="Button spacer"
                                           Style="{StaticResource MutedLabel}"
                                           Visibility="Hidden"/>
                                <Button x:Name="DisconnectButton"
                                        Content="Disconnect"
                                        Height="40"
                                        Background="{StaticResource Danger}"
                                        Click="DisconnectButton_Click"/>
                            </StackPanel>

                            <StackPanel Width="318" Margin="0,0,12,10">
                                <TextBlock Text="Hotkey" Style="{StaticResource MutedLabel}"/>
                                <Grid Height="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             x:Name="HotkeyTextBox"
                                             IsReadOnly="True"
                                             ToolTip="Click Change, then press a key. Examples: F8, Ctrl+F8, NumPad1, NumPad9, End, Slash."/>

                                    <Button Grid.Column="1"
                                            x:Name="ChangeHotkeyButton"
                                            Content="Change"
                                            Width="92"
                                            Height="40"
                                            Background="{StaticResource Secondary}"
                                            Margin="8,0,0,0"
                                            Click="ChangeHotkeyButton_Click"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel Width="150" Margin="0,0,0,10">
                                <TextBlock Text="Global hotkey spacer"
                                           Style="{StaticResource MutedLabel}"
                                           Visibility="Hidden"/>
                                <CheckBox x:Name="GlobalHotkeyCheckBox"
                                          Content="Global hotkey"
                                          Height="40"
                                          VerticalContentAlignment="Center"
                                          Click="GlobalHotkeyCheckBox_Click"
                                          ToolTip="If enabled, the hotkey works even when the game is focused."/>
                            </StackPanel>
                        </WrapPanel>

                        <TextBlock Grid.Row="2"
                                   Text="Start/Split can be triggered by the button, hotkey, or LiveSplit bridge. Finish is handled by the last split or admin correction."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="0.9*" MinWidth="280"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border x:Name="TopRightMeasure"
                            Grid.Column="1"
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            IsHitTestVisible="False"
                            Panel.ZIndex="-1"/>
                    <Border Grid.Column="0"
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            Height="{Binding ActualHeight, ElementName=TopRightMeasure}"
                            VerticalAlignment="Top"
                            Background="{StaticResource CardBackground}"
                            BorderBrush="#2A3040"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="18"
                            Margin="0,0,16,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Timer" Style="{StaticResource MutedLabel}"/>

                            <TextBlock Grid.Row="1"
                                       x:Name="TimerTextBlock"
                                       Text="0:00.000"
                                       Foreground="{StaticResource TextStrong}"
                                       FontSize="56"
                                       FontWeight="Black"
                                       FontFamily="Consolas"
                                       Margin="0,-2,0,0"/>

                            <Border Grid.Row="2"
                                    Background="{StaticResource CardBackgroundSoft}"
                                    BorderBrush="#273044"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14,12"
                                    Margin="0,8,0,12">
                                <StackPanel>
                                    <TextBlock Text="Current split"
                                               Style="{StaticResource MutedLabel}"/>
                                    <TextBlock x:Name="SplitTextBlock"
                                               Text="Not connected"
                                               Foreground="{StaticResource TextStrong}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Splits" Style="{StaticResource MutedLabel}"/>

                                <Border Grid.Row="1"
                                        Background="{StaticResource FieldBackground}"
                                        BorderBrush="#2A3040"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="10"
                                        MinHeight="150">
                                    <ScrollViewer x:Name="SplitScrollViewer"
                                                  MaxHeight="330"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  PreviewMouseWheel="ChildScrollViewer_PreviewMouseWheel">
                                        <StackPanel x:Name="SplitListPanel"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Grid.Row="0"
                            Background="{StaticResource CardBackground}"
                            BorderBrush="#2A3040"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="Status" Style="{StaticResource MutedLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Ellipse x:Name="StatusDot"
                                         Width="11"
                                         Height="11"
                                         Fill="#FF9F9F"
                                         Margin="0,0,9,0"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusTextBlock"
                                           Text="Disconnected"
                                           Foreground="#FF9F9F"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <TextBlock Text="Last sync" Style="{StaticResource MutedLabel}"/>
                            <TextBlock x:Name="SyncStatusTextBlock"
                                       Text="—"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <TextBlock Text="Attempt" Style="{StaticResource MutedLabel}"/>
                            <TextBlock x:Name="AttemptTextBlock"
                                       Text="—"
                                       FontFamily="Consolas"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <TextBlock Text="Local log" Style="{StaticResource MutedLabel}"/>
                            <TextBlock x:Name="LogPathTextBlock"
                                       Text="—"
                                       Foreground="{StaticResource TextMuted}"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Grid.Row="1"
                            Background="{StaticResource CardBackground}"
                            BorderBrush="#2A3040"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="18"
						    Margin="0,14,0,0">
						<Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Camera" Style="{StaticResource MutedLabel}"/>

                            <Button Grid.Row="1"
                                    x:Name="CameraButton"
                                    Content="Start camera"
                                    Width="100"
                                    Height="38"
                                    HorizontalAlignment="Left"
                                    Padding="8,8"
                                    FontSize="13"
                                    Background="{StaticResource Secondary}"
                                    Click="CameraButton_Click"/>

                            <TextBlock Grid.Row="2"
                                       x:Name="CameraStatusTextBlock"
                                       Text="Connect to server first."
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       TextTrimming="None"
                                       LineStackingStrategy="BlockLineHeight"
                                       LineHeight="16"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                       Margin="0,8,0,10"/>

                            <Border Grid.Row="3"
                                    Background="{StaticResource FieldBackground}"
                                    BorderBrush="#2A3040"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Height="168"
                                    ClipToBounds="True">
                                <wv2:WebView2 x:Name="CameraWebView" Visibility="Collapsed"/>
                            </Border>
                        </Grid>
                    </Border>

                </Grid>

                <Border Grid.Row="3"
                        Background="{StaticResource CardBackground}"
                        BorderBrush="#2A3040"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="18"
                        Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="124"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Log" Style="{StaticResource MutedLabel}"/>

                        <TextBox Grid.Row="1"
                                 x:Name="LogTextBox"
                                 Background="{StaticResource FieldBackground}"
                                 Foreground="{StaticResource TextMain}"
                                 BorderBrush="#2A3040"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
